      <aliases enabled='yes' />
      <column caption='Total Orders CNT' datatype='integer' name='[Calculation_0001082394689566]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([order_id])' />
      </column>
      <column caption='On Time Orders' datatype='integer' name='[Calculation_0001082394988576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;IF [delivery_performance] = &apos;On Time&apos; THEN 1 ELSE 0 END&#10;)' />
      </column>
      <column caption='Early Orders' datatype='integer' name='[Calculation_0001082395168801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;IF [delivery_performance] = &apos;Early&apos; THEN 1 ELSE 0 END&#10;)' />
      </column>
      <column caption='Late Delivery Rate' datatype='real' default-format='p0.0%' name='[Calculation_0001082395344930]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0014688623788046] / [total_orders]' />
      </column>
      <column caption='Avg Delay Minutes (Late)' datatype='real' name='[Calculation_0001082395795491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#10;IF [delivery_performance] = &apos;Late&apos; THEN [Calculation_0001082398494758] END&#10;)' />
      </column>
      <column caption='Overall Late Delivery Rate' datatype='real' name='[Calculation_0001082395942948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF [delivery_performance] = &apos;Late&apos; THEN 1 ELSE 0 END) / COUNT([order_id]) }' />
      </column>
      <column caption='Avg Rating' datatype='real' name='[Calculation_0001082396090405]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([rating])' />
      </column>
      <column caption='Delay Minutes' datatype='integer' name='[Calculation_0001082398494758]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;minute&apos;, [promised_delivery_time], [actual_delivery_time])' />
      </column>
      <column caption='Late Flag' datatype='integer' name='[Calculation_0014688623788046]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [delivery_performance] = &apos;Late&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Percent Orders' datatype='real' name='[Calculation_0014688632688656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([order_id]) / TOTAL(COUNT([order_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
